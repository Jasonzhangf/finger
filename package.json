{
  "name": "fingerdaemon",
  "version": "0.1.392",
  "description": "Finger - AI Agent Orchestrator with bd project management",
  "main": "dist/cli/index.js",
  "bin": {
    "myfinger": "./dist/cli/index.js",
    "finger-gateway-bridge": "./dist/cli/finger-gateway-bridge.js",
    "finger-config": "./dist/cli/finger-config.js",
    "apply_patch": "./dist/cli/apply-patch.js"
  },
  "type": "module",
  "scripts": {
    "build:precheck": "node scripts/prebuild-check.mjs",
    "build": "bash scripts/run-build-step.sh bash -lc 'npm run build:precheck && npm run build:backend:raw && npm run build:ui:raw'",
    "build:backend": "bash scripts/run-build-step.sh bash -lc 'npm run build:backend:raw'",
    "build:backend:raw": "npm run test:session-regression && tsc --noEmit false && npm run test:compact-projection-regression && chmod +x dist/cli/index.js && npm run build:rust:raw && npm run test:regression:full",
    "build:ui": "bash scripts/run-build-step.sh bash -lc 'npm run build:ui:raw'",
    "build:ui:raw": "npm --prefix ui run build",
    "build:rust": "bash scripts/run-build-step.sh bash -lc 'npm run build:rust:raw'",
    "build:rust:raw": "cargo build --release --workspace --manifest-path rust/Cargo.toml && bash scripts/copy-rust-binaries.sh && npm run test:rust:compact-regression",
    "build:bump-version": "node scripts/bump-build-version.mjs",
    "build:dev": "node scripts/set-progress-context-mode.mjs dev && npm run build",
    "build:release": "node scripts/set-progress-context-mode.mjs release && npm run build",
    "build:install": "bash scripts/build-and-install.sh",
    "dev": "tsx watch src/cli/index.ts",
    "start": "node dist/server/index.js",
    "cli": "node dist/cli/index.js",
    "install:global": "bash -lc 'PKG=$(npm pack --silent) && npm install -g \"$PKG\" && rm -f \"$PKG\"'",
    "server:dev": "tsx watch src/server/index.ts",
    "test": "vitest run",
    "start:services": "./scripts/start-services.sh",
    "start:iflow": "tsx scripts/start-iflow.ts",
    "test:watch": "vitest",
    "test:regression:full": "vitest run",
    "test:rust:compact-regression": "cargo test -p finger-kernel-model compact --manifest-path rust/Cargo.toml",
    "lint": "eslint src tests",
    "lint:fix": "eslint src tests --fix",
    "bd:init": "bd init --no-db",
    "bd:ready": "bd --no-db ready",
    "bd:create": "bd --no-db create",
    "check": "npm run lint && npm run test && npm run build",
    "test:ui": "vitest run --workspace ui --coverage",
    "finger:understand": "node dist/cli/index.js understand",
    "finger:route": "node dist/cli/index.js route",
    "finger:plan": "node dist/cli/index.js plan",
    "finger:execute": "node dist/cli/index.js execute",
    "finger:review": "node dist/cli/index.js review",
    "finger:orchestrate": "node dist/cli/index.js orchestrate",
    "daemon:guard": "node scripts/daemon-guard.cjs",
    "daemon:start": "node scripts/daemon-restart.cjs --start-only",
    "daemon:stop": "node scripts/daemon-stop.cjs",
    "daemon:restart": "node scripts/daemon-restart.cjs",
    "daemon:cleanup": "node scripts/daemon-cleanup.cjs",
    "digest:backfill:all": "tsx scripts/digest-backfill-all.ts",
    "logs:cleanup": "node scripts/log-cleanup.cjs",
    "logs:cleanup:all": "node scripts/log-cleanup.cjs --all",
    "test:context-rebuild:interleaved": "vitest run tests/unit/runtime/context-builder-interleaved-topics.test.ts",
    "evidence:context-rebuild:interleaved": "tsx scripts/context-rebuild/generate-interleaved-evidence.ts",
    "evidence:context-rebuild:real-runtime": "tsx scripts/context-rebuild/run-real-runtime-interleaved-e2e.ts",
    "test:update-plan-v2-gate": "vitest run tests/unit/tools/internal/codex-update-plan-tool.test.ts tests/unit/tools/internal/codex-update-plan-tool-v2.test.ts tests/integration/update-plan-v2-workflow.test.ts && npm run build:backend:raw",
    "test:session-regression": "vitest run tests/unit/server/message-helpers-session.test.ts tests/unit/server/dispatch-session-selection.test.ts tests/unit/server/channel-session-selection.test.ts tests/unit/server/channel-bridge-hub-route.test.ts tests/unit/server/agent-runtime-dispatch-guard.test.ts tests/unit/server/finger-role-modules-bootstrap-gating.test.ts tests/unit/server/message-route-preflight-compact.test.ts tests/modules/agent-status-subscriber-sanitization.test.ts tests/modules/agent-dispatch-tags.test.ts tests/unit/runtime/auto-compact.test.ts tests/unit/runtime/runtime-facade-compaction-summarizer.test.ts tests/unit/orchestration/context-ledger-compact.regression.test.ts tests/integration/runtime/compact-integration.test.ts",
    "test:compact-projection-regression": "vitest run tests/unit/server/message-route-execution-compact-session-sync.test.ts tests/integration/session-compact-projection-regression.test.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.40.1",
    "@zilliz/milvus2-sdk-node": "^2.5.9",
    "axios": "^1.14.0",
    "chalk": "^5.4.0",
    "commander": "^11.1.0",
    "express": "^5.2.1",
    "js-tiktoken": "^1.0.21",
    "mem0ai": "^2.3.0",
    "ora": "^9.3.0",
    "ws": "^8.18.0",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/express": "^5.0.6",
    "@types/node": "^20.10.0",
    "@types/ws": "^8.5.13",
    "@vitest/coverage-v8": "^1.6.1",
    "eslint": "^9.18.0",
    "execa": "^8.0.1",
    "globals": "^15.14.0",
    "tsx": "^4.19.2",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^1.6.0"
  },
  "fingerBuildVersion": "0.1.392",
  "pnpm": {
    "packageExtensions": {
      "vitest@*": {
        "dependencies": {
          "execa": "^8.0.1"
        }
      }
    }
  }
}
